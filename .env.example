# MongoDB
NUXT_MONGODB_URI=
NUXT_MONGODB_DATABASE=curatory

# Session (at least 32 random characters; for example: openssl rand -base64 32)
NUXT_SESSION_PASSWORD=

# Registration allowlist. Separate multiple addresses with commas.
NUXT_AUTH_ALLOWED_EMAILS=

# Optional Cloudflare Turnstile. If the secret key is set, login/register require a valid token.
NUXT_PUBLIC_TURNSTILE_SITE_KEY=
NUXT_TURNSTILE_SECRET_KEY=

# S3 / R2 storage
NUXT_S3_ACCESS_KEY_ID=
NUXT_S3_SECRET_ACCESS_KEY=
NUXT_S3_BUCKET=
NUXT_S3_REGION=
NUXT_S3_ENDPOINT=
NUXT_S3_PUBLIC_URL=

# AWS S3 example
# NUXT_S3_REGION=us-east-1
# NUXT_S3_ENDPOINT=
# NUXT_S3_PUBLIC_URL=https://my-bucket.s3.us-east-1.amazonaws.com

# Cloudflare R2 example
# NUXT_S3_REGION=auto
# NUXT_S3_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
# NUXT_S3_PUBLIC_URL=https://photos.example.com

# Optional analytics
NUXT_PUBLIC_GTAG_ID=
